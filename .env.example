# ── ContextForge gateway ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=4444
AUTH_REQUIRED=true
# 32+ char secret (demo only — change for anything real)
JWT_SECRET_KEY=demo-only-change-me-0123456789abcdef
AUTH_ENCRYPTION_SECRET=demo-encryption-secret-0123456789aa
PLATFORM_ADMIN_EMAIL=admin@finbyte.demo
PLATFORM_ADMIN_PASSWORD=FinByteAdmin!2026
PLATFORM_ADMIN_FULL_NAME=FinByte Admin
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=pass
MCPGATEWAY_UI_ENABLED=true
MCPGATEWAY_ADMIN_API_ENABLED=true
# ContextForge forces the bootstrapped admin to rotate its password on first UI
# login (admin_require_password_change_on_bootstrap=True, privileged min length
# 22). That's a stage blocker — disable the enforcement for the demo. Complexity
# policy itself stays on (password_policy_enabled=True), so the "Password Security"
# story is still real; we just don't force a rotation on stage.
PASSWORD_CHANGE_ENFORCEMENT_ENABLED=false

# ── A2A ─────────────────────────────────────────────────────────────────
MCPGATEWAY_A2A_ENABLED=true

# ── SSRF: allow the Compose private network so the gateway can reach
#    backend MCP servers / A2A agents by their service name ──────────────
SSRF_ALLOW_PRIVATE_NETWORKS=true
SSRF_ALLOW_LOCALHOST=true

# ── Plugins (PII/secrets, injection filter, unified PDP) ────────────────
PLUGINS_ENABLED=true
PLUGIN_CONFIG_FILE=/app/plugins/config.yaml

# ── OPA sidecar (policy decision point) ─────────────────────────────────
OPA_URL=http://opa:8181

# ── Database (lite=sqlite; full profile overrides with postgres) ────────
DATABASE_URL=sqlite:////data/mcp.db

# Local HTTP demo: disable CSRF (Secure cookie is HTTPS-only). Keep on behind HTTPS in prod.
CSRF_ENABLED=false
